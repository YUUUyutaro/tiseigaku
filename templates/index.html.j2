<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>{{ site_title }}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="安全保障・地政学ニュースを AI で構造化し、図解付きで日次配信するアーカイブ">
  <style>
    :root { --fg:#111; --muted:#666; --line:#e5e5e5; --accent:#1e3a8a; --bg:#fff; }
    * { box-sizing: border-box; }
    body { font-family: -apple-system, "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
           color: var(--fg); background: var(--bg);
           max-width: 960px; margin: 0 auto; padding: 24px; line-height: 1.7; }
    header { border-bottom: 2px solid var(--accent); margin-bottom: 24px; padding-bottom: 16px; }
    h1 { margin: 0 0 8px; font-size: 28px; }
    .hero { color: var(--muted); margin: 4px 0; }
    .meta { color: var(--muted); font-size: 13px; }
    .report-card { border: 1px solid var(--line); border-radius: 8px; padding: 20px; margin: 20px 0;
                   transition: box-shadow 0.15s, transform 0.15s; }
    .report-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.08); transform: translateY(-1px); }
    .report-card h2 { margin: 0 0 6px; font-size: 20px; color: var(--accent); }
    .report-card h2 a { color: inherit; text-decoration: none; }
    .report-card h2 a:hover { text-decoration: underline; }
    .headlines { padding-left: 20px; margin: 10px 0; }
    .headlines li { margin: 4px 0; }
    .links { margin-top: 12px; font-size: 13px; }
    .links a { margin-right: 14px; color: var(--accent); text-decoration: none; }
    .links a:hover { text-decoration: underline; }
    .empty { color: var(--muted); padding: 40px 20px; text-align: center; border: 1px dashed var(--line); border-radius: 8px; }
    footer { color: var(--muted); font-size: 12px; margin-top: 40px; text-align: center;
             border-top: 1px solid var(--line); padding-top: 16px; }
  </style>
</head>
<body>
  <header>
    <h1>{{ site_title }}</h1>
    <p class="hero">安全保障・地政学ニュースを AI で構造化し、図解付きで日次配信するアーカイブ。</p>
    <p class="meta">インデックス更新: {{ generated_at }} · レポート数: {{ reports|length }}</p>
  </header>

  {% if not reports %}
  <div class="empty">まだレポートがありません。<br><code>python -m src.main --mock --site</code> を実行するとここに一覧が並びます。</div>
  {% endif %}
  {% for r in reports %}
  <article class="report-card">
    <h2><a href="{{ reports_subdir }}/{{ r.slug }}.html">{{ r.slug }} 号</a></h2>
    <div class="meta">記事 {{ r.count }} 本 · 生成 {{ r.generated_at }}</div>
    <ul class="headlines">
      {% for h in r.headlines %}<li>{{ h }}</li>{% endfor %}
    </ul>
    <div class="links">
      <a href="{{ reports_subdir }}/{{ r.slug }}.html">HTML 版(図解あり)</a>
      <a href="{{ reports_subdir }}/{{ r.slug }}.md">Markdown 版</a>
    </div>
  </article>
  {% endfor %}

  <footer>地政学ニュース図解ジェネレータ — Powered by Claude</footer>
</body>
</html>
